        <a href="#"><img src="~/slideshow/02.jpg" alt="nature 2" title="Fusce eget tellus eget felis ultrices volutpat et vitae mauris." /></a>
        <a href="#"><img src="~/slideshow/03.jpg" alt="nature 3" title="Duis non est nec dui tincidunt pulvinar lacinia vel quam." /></a>
        <a href="#"><img src="~/slideshow/04.jpg" alt="nature 4" title="Phasellus in orci eget neque tristique semper ut ac lacus." /></a>
        
        <div class="nivo-caption">
            <p id="slider-caption-text">Suspendisse quis velit ac nisl ultrices tristique a eu velit.</p>
        </div>
    </div>
</div>

<section class="greenage-services">
    <h1>Welcome to Green Age</h1>

    <div class="greenage-services-grid">
        <article class="greenage-service">
            <img src="~/icon1.png" alt="Download free templates" class="greenage-service-icon" />
            <div class="greenage-service-content">
                <h2>Download Free Templates</h2>
                <p>
                    Green Age is a free <span class="greenage-highlight">website template</span> for everyone.
                    You may edit and apply this template for any purpose.
                </p>
                <a href="#" class="greenage-more-btn">More</a>
            </div>
        </article>

        <article class="greenage-service">
            <img src="~/icon2.png" alt="Online marketing" class="greenage-service-icon" />
            <div class="greenage-service-content">
                <h2>Online Marketing</h2>
                <p>
                    Sed et eros ac mauris suscipit viverra. Sed et eros ac mauris suscipit viverra.
                    Validate <span class="greenage-highlight">XHTML</span> and <span class="greenage-highlight">CSS</span>.
                </p>
                <a href="#" class="greenage-more-btn">More</a>
            </div>
        </article>
    </div>
</section>

@section Scripts {
    <script>
        $(document).ready(function() {
            var $slides = $('#slider a:not(.nivo-caption)');
            var $caption = $('#slider-caption-text');
            var currentIndex = 0;
            
            setInterval(function() {
                var $current = $slides.eq(currentIndex);
                $current.removeClass('active');
                
                currentIndex = (currentIndex + 1) % $slides.length;
                
                var $next = $slides.eq(currentIndex);
                $next.addClass('active');
                $caption.text($next.find('img').attr('title'));
            }, 5000);
        });
    </script>
}